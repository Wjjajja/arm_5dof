<?xml version="1.0"?>
<robot name="5dof_arm">

  <material name="dark_gray">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="light_gray">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>

  <!-- world fixed joint -->
  <link name="world"/>
  <joint name="world_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="world"/>
    <child link="base_link"/>
  </joint>

  <!-- base_link -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://arm_5dof/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://arm_5dof/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="1.0" ixy="0" ixz="0"
               iyy="1.0" iyz="0"
               izz="1.0"/>
    </inertial>
  </link>

  <!-- link0: visual offset = -J0 절대좌표 -->
  <link name="link0">
    <visual>
      <origin xyz="0 -0.0005 -0.131" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://arm_5dof/meshes/link0.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 -0.0005 -0.131" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://arm_5dof/meshes/link0.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.00166076 -0.00127550 -0.03494810" rpy="0 0 0"/>
      <mass value="0.953077"/>
      <inertia
        ixx="5.159255e-03" ixy="2.158307e-05" ixz="7.896207e-04"
        iyy="5.327866e-03" iyz="-1.540990e-04"
        izz="6.453667e-04"/>
    </inertial>
  </link>

  <!-- link1: visual offset = -J1 절대좌표 -->
  <link name="link1">
    <visual>
      <origin xyz="-0.069 -0.0015 -0.164" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://arm_5dof/meshes/link1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="-0.069 -0.0015 -0.164" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://arm_5dof/meshes/link1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.00020657 0.00264022 0.09988650" rpy="0 0 0"/>
      <mass value="1.313615"/>
      <inertia
        ixx="4.105084e-02" ixy="-9.571784e-06" ixz="9.581033e-04"
        iyy="4.160133e-02" iyz="2.130310e-04"
        izz="1.163477e-03"/>
    </inertial>
  </link>

  <!-- link2: visual offset = -J2 절대좌표 -->
  <link name="link2">
    <visual>
      <origin xyz="-0.0575 -0.0015 -0.4125" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://arm_5dof/meshes/link2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="-0.0575 -0.0015 -0.4125" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://arm_5dof/meshes/link2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.00070402 0.00107153 0.29442261" rpy="0 0 0"/>
      <mass value="0.848993"/>
      <inertia
        ixx="6.563250e-02" ixy="1.816882e-07" ixz="3.138284e-04"
        iyy="6.603089e-02" iyz="-1.444540e-04"
        izz="7.080727e-04"/>
    </inertial>
  </link>

  <!-- link3: visual offset = -J3 절대좌표 -->
  <link name="link3">
    <visual>
      <origin xyz="-0.0455 -0.0015 -0.644491" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://arm_5dof/meshes/link3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="-0.0455 -0.0015 -0.644491" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://arm_5dof/meshes/link3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.00050190 -0.00086335 0.16206518" rpy="0 0 0"/>
      <mass value="0.371908"/>
      <inertia
        ixx="3.748271e-02" ixy="-5.366650e-07" ixz="-7.724617e-05"
        iyy="3.755020e-02" iyz="-1.771748e-04"
        izz="1.789698e-04"/>
    </inertial>
  </link>

  <!-- link4: visual offset = -J4 절대좌표 -->
  <link name="link4">
    <visual>
      <origin xyz="-0.0005 -0.0015 -0.763154" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://arm_5dof/meshes/link4.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="light_gray"/>
    </visual>
    <collision>
      <origin xyz="-0.0005 -0.0015 -0.763154" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://arm_5dof/meshes/link4.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.00050000 0.00150000 0.76650600" rpy="0 0 0"/>
      <mass value="0.017299"/>
      <inertia
        ixx="3.095422e-06" ixy="0" ixz="0"
        iyy="6.041748e-06" iyz="0"
        izz="8.821226e-06"/>
    </inertial>
  </link>

  <!-- J0: Roll -->
  <joint name="joint0" type="revolute">
    <origin xyz="0 0.0005 0.131" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <parent link="base_link"/>
    <child link="link0"/>
    <limit lower="-3.14159" upper="3.14159" effort="200" velocity="1.0"/>
  </joint>

  <!-- J1: Pitch -->
  <joint name="joint1" type="revolute">
    <origin xyz="0.069 0.001 0.033" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <parent link="link0"/>
    <child link="link1"/>
    <limit lower="-1.5708" upper="1.5708" effort="200" velocity="1.0"/>
  </joint>

  <!-- J2: Pitch -->
  <joint name="joint2" type="revolute">
    <origin xyz="-0.0115 0 0.2485" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <parent link="link1"/>
    <child link="link2"/>
    <limit lower="-1.5708" upper="1.5708" effort="100" velocity="1.0"/>
  </joint>

  <!-- J3: Pitch -->
  <joint name="joint3" type="revolute">
    <origin xyz="-0.012 0 0.231991" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <parent link="link2"/>
    <child link="link3"/>
    <limit lower="-1.5708" upper="1.5708" effort="20" velocity="1.0"/>
  </joint>

  <!-- J4: Roll -->
  <joint name="joint4" type="revolute">
    <origin xyz="-0.045 0 0.118663" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <parent link="link3"/>
    <child link="link4"/>
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="1.0"/>
  </joint>

  <!-- ros2_control -->
  <ros2_control name="5dof_arm_control" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="joint0">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint1">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint2">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint3">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint4">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- Gazebo plugin -->
  <gazebo>
    <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>package://arm_5dof/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
